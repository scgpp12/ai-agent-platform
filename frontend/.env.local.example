# CDK の Outputs を貼る（Vercel では Project Settings > Environment Variables に設定）
NEXT_PUBLIC_API_URL=https://xxxxxx.execute-api.ap-northeast-1.amazonaws.com
NEXT_PUBLIC_COGNITO_AUTHORITY=https://cognito-idp.ap-northeast-1.amazonaws.com/ap-northeast-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_COGNITO_DOMAIN=aiagent-603319838936.auth.ap-northeast-1.amazoncognito.com
# ローカル開発は http://localhost:3000/ 、Vercel は https://<your-app>.vercel.app/
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/
