# ===== LLM Provider =====
# echo = モデル不要のフォールバック（まず動かす）／ ollama = 本物のLLM
LLM_BACKEND=echo
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# 埋め込み: hashing(純Python) / ollama(bge-m3)
EMBED_BACKEND=hashing
OLLAMA_EMBED_MODEL=bge-m3

# ===== 認証 =====
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
# 1 にすると JWT 検証をスキップ（ローカルcurl練習用）。本番は必ず 0。
DEV_NO_AUTH=0

# ===== オーケストレーション =====
STEP_TIMEOUT=60
