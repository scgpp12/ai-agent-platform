# ===== LLM Provider =====
# echo=免模型兜底 / ollama=Ollama原生 / bedrock=AWS / llamaswap=sons02的llama-swap(本地免费)
LLM_BACKEND=echo
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# llama-swap (sons02 :8080, OpenAI兼容)。LLM_BACKEND=llamaswap 时生效。
# 本机直连局域网即可；模型列表见 GET http://10.32.1.41:8080/v1/models
LLAMASWAP_BASE_URL=http://10.32.1.41:8080/v1
LLAMASWAP_MODEL=qwen3.6

# 埋め込み: hashing(純Python) / ollama(bge-m3) / bedrock(Titan)
# 注: llama-swap 无嵌入模型，用 llamaswap 做 LLM 时 EMBED 仍走 hashing 或 bedrock
EMBED_BACKEND=hashing
OLLAMA_EMBED_MODEL=bge-m3

# ===== 認証 =====
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
# 1 にすると JWT 検証をスキップ（ローカルcurl練習用）。本番は必ず 0。
DEV_NO_AUTH=0

# ===== オーケストレーション =====
STEP_TIMEOUT=60
